# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# Stripe (Phase 4/10 — test mode keys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Connect Express OAuth/Connect client id, if using account links flow
STRIPE_CONNECT_CLIENT_ID=

# Email delivery (invoices + reminders) — Resend recommended
RESEND_API_KEY=
EMAIL_FROM="Slate <invoices@yourdomain.com>"

# Used to build absolute links in emails / Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to authorize the daily reminder cron endpoint
CRON_SECRET=

# Cal.com booking link for the "Book a demo" link on the landing page
CALCOM_LINK=https://cal.com/slatetutor
